# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
APP_NAME="AI Product Intelligence Platform"
APP_ENV=local
APP_DEBUG=true
APP_VERSION=1.0.0

# ─────────────────────────────────────────────────────────────────────────────
# API
# ─────────────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# Database (MySQL)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/qumta_db
DATABASE_URL_SYNC=mysql+pymysql://root:password@localhost:3306/qumta_db

# ─────────────────────────────────────────────────────────────────────────────
# Authentication (JWT)
# ─────────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Token blacklist via Redis (set to false if Redis is not running in dev)
ENABLE_TOKEN_BLACKLIST=true

# ─────────────────────────────────────────────────────────────────────────────
# Redis (used by Celery and token blacklist)
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─────────────────────────────────────────────────────────────────────────────
# File Storage
# Options: local | s3
# ─────────────────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=storage/uploads

# AWS S3 / compatible (only needed when STORAGE_DRIVER=s3)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=qumta-uploads
AWS_S3_ENDPOINT_URL=               # Leave blank for real AWS; set for MinIO/Wasabi

# ─────────────────────────────────────────────────────────────────────────────
# pgvector (embeddings)
# ─────────────────────────────────────────────────────────────────────────────
EMBEDDING_DIMENSIONS=1536           # OpenAI ada-002 / text-embedding-3-small

# ─────────────────────────────────────────────────────────────────────────────
# AI Service Keys (placeholder — fill when integrating)
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-placeholder
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_KEY=
